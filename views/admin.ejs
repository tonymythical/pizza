<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Page</title>

    <!-- Scripts -->
    <script src="//code.jquery.com/jquery-3.7.1.js"></script>
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.js"></script>

    <!-- Styles -->
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.css" />
</head>
<body>
    <h1>Order Summary</h1>
    <table id="order-table" class="display" style="width:100%">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Pickup or Delivery</th>
                <th>Toppings</th>
                <th>Size</th>
                <th>Comments</th>
                <th>Date/Time</th>
            </tr>
        </thead>
        <tbody>
            <% orders.forEach(order => { %>
                <tr>
                    <td><%= order.fname %> <%= order.lname %></td>
                    <td><%= order.email %></td>
                    <td><%= order.method %></td>
                    <td><%= Array.isArray(order.toppings) ? order.toppings.join(", ") : order.toppings %></td>
                    <td><%= order.size %></td>
                    <td><%= order.comments %></td>
                    <td><%= order.timestamp %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    <script defer>
        let table = new DataTable('#order-table');
    </script>
</body>
</html>